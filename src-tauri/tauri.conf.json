{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "solara",
  "version": "0.1.0",
  "identifier": "com.souleyez.solara",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "solara",
        "width": 360,
        "height": 220,
        "resizable": false,
        "center": true
      },
      {
        "label": "pet",
        "url": "pet.html",
        "title": "solara",
        "width": 160,
        "height": 160,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "focusable": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
